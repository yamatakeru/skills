{
  "$schema": "https://opencode.ai/config.json",

  // Project-level default. Replace with your preferred main model.
  // You can also omit this and rely on your global OpenCode config.
  "model": "openai/gpt-5.5",

  "permission": {
    // Let agents load the fusion-council skill without prompting.
    "skill": {
      "*": "ask",
      "fusion-council": "allow",
    },
  },

  "agent": {
    // Optional: tune the built-in primary agents so they can call the hidden Fusion subagents.
    "build": {
      "permission": {
        "skill": {
          "*": "ask",
          "fusion-council": "allow",
        },
        "task": {
          "*": "ask",
          "fusion-*": "allow",
        },
      },
    },

    "plan": {
      "permission": {
        "skill": {
          "*": "ask",
          "fusion-council": "allow",
        },
        "task": {
          "*": "ask",
          "fusion-*": "allow",
        },
        "edit": "deny",
        "bash": "ask",
      },
    },
  },
}
