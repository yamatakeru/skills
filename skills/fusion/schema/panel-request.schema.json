{
  "$ref": "#/definitions/PanelRequest",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "ContextManifest": {
      "additionalProperties": false,
      "properties": {
        "files": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "digest": {
                "type": "string"
              },
              "path": {
                "type": "string"
              }
            },
            "required": [
              "path",
              "digest"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "references": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "digest": {
                "type": "string"
              },
              "label": {
                "type": "string"
              }
            },
            "required": [
              "label",
              "digest"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "renderedPromptHash": {
          "type": "string"
        },
        "sharedContextHash": {
          "type": "string"
        },
        "userTaskHash": {
          "type": "string"
        }
      },
      "required": [
        "renderedPromptHash",
        "sharedContextHash"
      ],
      "type": "object"
    },
    "FindingKind": {
      "enum": [
        "consensus",
        "contradictions",
        "partial-coverage",
        "unique-insights",
        "blind-spots"
      ],
      "type": "string"
    },
    "HarnessKind": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "enum": [
            "opencode",
            "cursor",
            "claude-code",
            "pi"
          ],
          "type": "string"
        }
      ]
    },
    "HarnessPreference": {
      "additionalProperties": false,
      "properties": {
        "invocation": {
          "$ref": "#/definitions/InvocationMode"
        },
        "kind": {
          "$ref": "#/definitions/HarnessKind"
        },
        "transport": {
          "$ref": "#/definitions/TransportMode"
        },
        "version": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "HarnessSelectionPolicy": {
      "additionalProperties": false,
      "properties": {
        "availableHarnesses": {
          "items": {
            "$ref": "#/definitions/HarnessKind"
          },
          "type": "array"
        },
        "requiredCapabilities": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "userPolicy": {
          "additionalProperties": {},
          "type": "object"
        }
      },
      "type": "object"
    },
    "InvocationMode": {
      "enum": [
        "headless",
        "subagent"
      ],
      "type": "string"
    },
    "ModelPreference": {
      "additionalProperties": false,
      "properties": {
        "aliases": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "fallbacks": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "model": {
          "type": "string"
        },
        "provider": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "NonJudgeSynthesizerStrategy": {
      "enum": [
        "parent-agent",
        "deterministic"
      ],
      "type": "string"
    },
    "PanelRequest": {
      "additionalProperties": false,
      "properties": {
        "contextManifest": {
          "$ref": "#/definitions/ContextManifest"
        },
        "harnessSelectionPolicy": {
          "$ref": "#/definitions/HarnessSelectionPolicy"
        },
        "panelRunId": {
          "type": "string"
        },
        "panelSpec": {
          "$ref": "#/definitions/PanelSpec"
        },
        "prompt": {
          "type": "string"
        },
        "provenancePolicy": {
          "$ref": "#/definitions/ProvenancePolicy"
        },
        "reasoning": {
          "$ref": "#/definitions/ReasoningPreference"
        },
        "sharedContext": {
          "$ref": "#/definitions/SharedContext"
        },
        "synthesisContract": {
          "$ref": "#/definitions/SynthesisContract"
        },
        "synthesizer": {
          "$ref": "#/definitions/SynthesizerPreference"
        },
        "workerBudget": {
          "$ref": "#/definitions/WorkerBudget"
        },
        "workerEnvironment": {
          "$ref": "#/definitions/WorkerEnvironment"
        }
      },
      "required": [
        "panelRunId",
        "prompt",
        "sharedContext",
        "contextManifest",
        "panelSpec",
        "harnessSelectionPolicy",
        "synthesisContract"
      ],
      "type": "object"
    },
    "PanelSpec": {
      "additionalProperties": false,
      "properties": {
        "parentModel": {
          "$ref": "#/definitions/ModelPreference"
        },
        "workerCount": {
          "description": "Kept in sync with MAX_PANEL_WORKERS in validation.ts.",
          "maximum": 20,
          "minimum": 1,
          "type": "number"
        },
        "workers": {
          "items": {
            "$ref": "#/definitions/WorkerSlotPreference"
          },
          "type": "array"
        }
      },
      "required": [
        "workerCount"
      ],
      "type": "object"
    },
    "ProvenancePolicy": {
      "additionalProperties": false,
      "properties": {
        "eventLog": {
          "type": "boolean"
        },
        "includeModelMetadata": {
          "type": "boolean"
        },
        "includeToolLogs": {
          "type": "boolean"
        },
        "record": {
          "type": "boolean"
        },
        "redactSecrets": {
          "type": "boolean"
        },
        "requireMinimumEventsForFullCompliance": {
          "type": "boolean"
        }
      },
      "required": [
        "record",
        "redactSecrets",
        "eventLog",
        "requireMinimumEventsForFullCompliance",
        "includeToolLogs",
        "includeModelMetadata"
      ],
      "type": "object"
    },
    "ReasoningPreference": {
      "additionalProperties": false,
      "properties": {
        "effort": {
          "enum": [
            "low",
            "medium",
            "high",
            "xhigh"
          ],
          "type": "string"
        },
        "maxTokens": {
          "type": "number"
        }
      },
      "type": "object"
    },
    "SharedContext": {
      "additionalProperties": false,
      "properties": {
        "files": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "content": {
                "type": "string"
              },
              "digest": {
                "type": "string"
              },
              "path": {
                "type": "string"
              }
            },
            "required": [
              "path"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "references": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "digest": {
                "type": "string"
              },
              "label": {
                "type": "string"
              },
              "uri": {
                "type": "string"
              }
            },
            "required": [
              "label"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "text": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "SynthesisContract": {
      "additionalProperties": false,
      "properties": {
        "allowPartial": {
          "type": "boolean"
        },
        "format": {
          "enum": [
            "markdown",
            "json"
          ],
          "type": "string"
        },
        "requireAttribution": {
          "type": "boolean"
        },
        "requiredFindings": {
          "items": {
            "$ref": "#/definitions/FindingKind"
          },
          "type": "array"
        }
      },
      "required": [
        "requiredFindings",
        "format",
        "allowPartial",
        "requireAttribution"
      ],
      "type": "object"
    },
    "SynthesizerPreference": {
      "additionalProperties": false,
      "properties": {
        "model": {
          "$ref": "#/definitions/ModelPreference"
        },
        "strategy": {
          "anyOf": [
            {
              "$ref": "#/definitions/NonJudgeSynthesizerStrategy"
            },
            {
              "$ref": "#/definitions/HarnessKind"
            }
          ]
        }
      },
      "required": [
        "strategy"
      ],
      "type": "object"
    },
    "TransportMode": {
      "enum": [
        "cli",
        "sdk"
      ],
      "type": "string"
    },
    "WorkerBudget": {
      "additionalProperties": false,
      "properties": {
        "maxInputTokens": {
          "type": "number"
        },
        "maxOutputTokens": {
          "type": "number"
        },
        "maxToolCalls": {
          "type": "number"
        },
        "maxTurns": {
          "type": "number"
        },
        "timeoutMs": {
          "type": "number"
        }
      },
      "type": "object"
    },
    "WorkerEnvironment": {
      "additionalProperties": false,
      "properties": {
        "envProfile": {
          "type": "string"
        },
        "readRoots": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "workingDirectory": {
          "type": "string"
        },
        "workspaceRoot": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "WorkerSlotPreference": {
      "additionalProperties": false,
      "properties": {
        "harness": {
          "$ref": "#/definitions/HarnessPreference"
        },
        "model": {
          "$ref": "#/definitions/ModelPreference"
        }
      },
      "type": "object"
    }
  }
}