{
  "$ref": "#/definitions/WorkerResult",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "ContainmentLevel": {
      "enum": [
        "no-shell",
        "allowlist-enforced",
        "sandboxed"
      ],
      "type": "string"
    },
    "EnforcementSource": {
      "enum": [
        "verified-effective",
        "harness-declared"
      ],
      "type": "string"
    },
    "HarnessDescriptor": {
      "additionalProperties": false,
      "properties": {
        "invocation": {
          "$ref": "#/definitions/InvocationMode"
        },
        "kind": {
          "$ref": "#/definitions/HarnessKind"
        },
        "transport": {
          "$ref": "#/definitions/TransportMode"
        },
        "version": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "invocation"
      ],
      "type": "object"
    },
    "HarnessKind": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "enum": [
            "opencode",
            "cursor",
            "claude-code",
            "pi"
          ],
          "type": "string"
        }
      ]
    },
    "InvocationMode": {
      "enum": [
        "headless",
        "subagent"
      ],
      "type": "string"
    },
    "RuntimeToolEvent": {
      "additionalProperties": false,
      "properties": {
        "command": {
          "type": "string"
        },
        "outcome": {
          "enum": [
            "started",
            "succeeded",
            "denied",
            "failed",
            "unknown"
          ],
          "type": "string"
        },
        "tool": {
          "type": "string"
        }
      },
      "required": [
        "tool"
      ],
      "type": "object"
    },
    "SessionMode": {
      "enum": [
        "fresh",
        "fork",
        "resume"
      ],
      "type": "string"
    },
    "ToolUseSummary": {
      "additionalProperties": false,
      "properties": {
        "deniedRequests": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "promptRequests": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "toolsUsed": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "TransportMode": {
      "enum": [
        "cli",
        "sdk"
      ],
      "type": "string"
    },
    "UsageSummary": {
      "additionalProperties": false,
      "properties": {
        "costUsd": {
          "type": "number"
        },
        "durationMs": {
          "type": "number"
        },
        "inputTokens": {
          "type": "number"
        },
        "outputTokens": {
          "type": "number"
        }
      },
      "type": "object"
    },
    "WorkerAbortOutcome": {
      "additionalProperties": false,
      "properties": {
        "attempted": {
          "type": "boolean"
        },
        "error": {
          "type": "string"
        },
        "succeeded": {
          "type": "boolean"
        }
      },
      "required": [
        "attempted"
      ],
      "type": "object"
    },
    "WorkerComplianceEvidence": {
      "additionalProperties": false,
      "properties": {
        "adapterClaimsBlindness": {
          "type": "boolean"
        },
        "adapterClaimsCleanSameWorkerLineage": {
          "type": "boolean"
        },
        "adapterClaimsIndependentInvocation": {
          "type": "boolean"
        },
        "adapterClaimsIsolatedContext": {
          "type": "boolean"
        },
        "containment": {
          "$ref": "#/definitions/ContainmentLevel"
        },
        "enforcement": {
          "$ref": "#/definitions/WorkerEnforcementEvidence"
        },
        "notes": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "observedSessionMode": {
          "$ref": "#/definitions/SessionMode"
        }
      },
      "type": "object"
    },
    "WorkerEnforcementEvidence": {
      "additionalProperties": false,
      "properties": {
        "abortOutcome": {
          "$ref": "#/definitions/WorkerAbortOutcome"
        },
        "effectiveRules": {
          "additionalProperties": {},
          "description": "Effective harness rules observed independently of the request.",
          "type": "object"
        },
        "permissionDenialCount": {
          "description": "Permission denials demonstrate that enforcement operated as intended.",
          "minimum": 0,
          "type": "number"
        },
        "source": {
          "$ref": "#/definitions/EnforcementSource"
        },
        "toolEvents": {
          "items": {
            "$ref": "#/definitions/RuntimeToolEvent"
          },
          "type": "array"
        },
        "violationEvidence": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "source"
      ],
      "type": "object"
    },
    "WorkerResult": {
      "additionalProperties": false,
      "properties": {
        "complianceEvidence": {
          "$ref": "#/definitions/WorkerComplianceEvidence"
        },
        "errors": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "harnessUsed": {
          "$ref": "#/definitions/HarnessDescriptor"
        },
        "modelUsed": {
          "type": "string"
        },
        "output": {
          "type": "string"
        },
        "panelRunId": {
          "type": "string"
        },
        "sessionId": {
          "type": "string"
        },
        "status": {
          "$ref": "#/definitions/WorkerStatus"
        },
        "toolUseSummary": {
          "$ref": "#/definitions/ToolUseSummary"
        },
        "usage": {
          "$ref": "#/definitions/UsageSummary"
        },
        "warnings": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "workerId": {
          "type": "string"
        }
      },
      "required": [
        "panelRunId",
        "workerId",
        "status",
        "output"
      ],
      "type": "object"
    },
    "WorkerStatus": {
      "enum": [
        "ok",
        "timeout",
        "error",
        "invalid-output",
        "refused"
      ],
      "type": "string"
    }
  }
}